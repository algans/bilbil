# Bilbil — environment variables (kopyala: cp .env.example .env)

# ─── Database ────────────────────────────────────────────────────────────────
# Lokal docker-compose Postgres (port 5435 → diğer Postgres container'larıyla çakışmayı önler)
DATABASE_URL="postgresql://bilbil:bilbil_dev@localhost:5435/bilbil?schema=public"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# ÜRETİM ÖNCESİ MUTLAKA DEĞİŞTİR — gerçek bir secret üret:
#   openssl rand -base64 32
AUTH_SECRET="dev-secret-replace-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Sentry (opsiyonel — boşsa Sentry no-op çalışır) ─────────────────────────
# Production'da hata izleme için Sentry projesi açın ve DSN'i buraya yapıştırın.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Production'da gerçek key. Faz 1'de aktif olacak, MVP geliştirme sırasında console-log fallback.
RESEND_API_KEY=""
EMAIL_FROM="Bilbil <noreply@bilbil.app>"

# ─── AI (Faz 4.5 — AI ile Quiz Oluştur) ──────────────────────────────────────
# OpenAI API key (Server-side only — UI'dan asla expose edilmez)
# Yoksa "AI ile Quiz Oluştur" özelliği 503 döner; manuel quiz akışı çalışmaya devam eder.
OPENAI_API_KEY=""
# Model override — default "gpt-4o-mini" (fiyat/performans dengesi). "gpt-4o" daha yüksek kalite.
AI_MODEL="gpt-4o-mini"
# Test/CI için: 1 set edilirse OpenAI çağrılmaz, fixture cevap döner (tests/e2e için)
# AI_MOCK="0"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
# NEXT_PUBLIC_APP_URL sadece fallback olarak kullanılır — server.ts proxy/tunnel arkasında
# `host` header'ından runtime'da origin'i hesaplar (Cloudflare tunnel, Vercel, Fly.io).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
